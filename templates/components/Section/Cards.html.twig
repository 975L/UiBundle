{# Dynamic usage only (Block system): see templates/blocks/SectionCards.html.twig - "slots" is a
   collection of real Block entities (Entity/Block.php's "slots" relation), each rendered through the
   normal render_block() pipeline (own kind, own cache, own media). Wrapped in ".cards" (see
   sass/_cards.scss) instead of a dedicated grid, the same fixed-width flex row bare consecutive "card"
   blocks already get in the page flow (see Blocks.html.twig) - so a slot renders identically whether
   it sits here or bare in the page, this section only adds the eyebrow/title/anchor around it. #}
<section class="section-cards-section"{% if id is defined and id %} id="{{ id }}"{% endif %}>
    <div class="section-wrap">
        {% if eyebrow or title %}
            <div class="section-head">
                {% if eyebrow %}<p class="section-eyebrow">{{ eyebrow }}</p>{% endif %}
                {% if title %}<h2 class="section-title">{{ title }}</h2>{% endif %}
            </div>
        {% endif %}
        <div class="cards">
            {% for slot in slots %}
                {{ render_block(slot) }}
            {% endfor %}
        </div>
    </div>
</section>
