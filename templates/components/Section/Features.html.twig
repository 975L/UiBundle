{# Static usage: <twig:c975LUi:Section:Features cards="{{ [{icon: '', title: '...', text: '...'}] }}" [eyebrow=""] [title=""] [id=""]/> #}
{# Dynamic usage (Block system): see templates/blocks/SectionFeatures.html.twig #}
<section class="section-features-section"{% if id is defined and id %} id="{{ id }}"{% endif %}>
    <div class="section-wrap">
        {% if eyebrow or title %}
            <div class="section-head">
                {% if eyebrow %}<p class="section-eyebrow">{{ eyebrow }}</p>{% endif %}
                {% if title %}<h2 class="section-title">{{ title }}</h2>{% endif %}
            </div>
        {% endif %}
        <div class="section-features">
            {% for c in cards %}
                <twig:c975LUi:Card:Card title="{{ c.title }}" level="h3" icon="{{ c.icon ? [c.icon, '', 22, 22] : [] }}" content="{{ c.text }}"/>
            {% endfor %}
        </div>
    </div>
</section>
