{# Static usage  : <twig:c975LUi:Alert:Alert type="info">Your content</twig:c975LUi:Alert:Alert> #}
{# Dynamic usage : {{ render_block(block) }}  — data keys are spread as variables automatically #}

{% set type = type | default('info') %}
{% set content = content | default('') %}

<div class="alert alert-{{ type }} text-center">
    <twig:c975LUi:Image:Icon src="bundles/c975lsite/images/alert-{{ type }}.svg" width="16" height="16"/>
    {% block content %}{{ content }}{% endblock %}
</div>