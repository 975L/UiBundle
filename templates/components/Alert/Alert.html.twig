{# Static usage : <twig:c975LUi:Alert:Alert type="info">Your content</twig:c975LUi:Alert:Alert> #}
{# Dynamic usage (Block system) : see templates/blocks/Alert.html.twig #}

{% set type = type | default('info') %}
{% set content = content | default('') %}

<div class="alert alert-{{ type }} text-center">
    <twig:c975LUi:Image:Icon src="bundles/c975lsite/icons/alert-{{ type }}.svg" width="16" height="16"/>
    {% block content %}{{ content|raw|nl2br }}{% endblock %}
</div>