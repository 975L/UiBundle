{# Static usage : <twig:c975LUi:Slider:Slider media="{{ mediaList }}" id="id" duration="5000" [ratio="free"] [class=""] [label=""] /> #}
{# Rich usage (clickable title/text per slide) : <twig:c975LUi:Slider:Slider slides="{{ [{image: media, title: '', text: '', url: ''}, ...] }}" id="id" duration="5000" /> #}
{# Add imageLinksToUrl="true" to also make the image itself link to slide.url instead of advancing to the next slide #}
{% set label = label|default("label.pages_gallery"|trans({}, "site")) %}
{% set class = class|default([])|join(' ') %}
{% set ratio = ratio|default("free") %}
{% set slides = slides|default([]) %}
{% set imageLinksToUrl = imageLinksToUrl|default(false) %}
{% set mediaList = slides|length > 0 ? slides|map(slide => slide.image) : media|default([]) %}
{% if mediaList|length == 1 %}
    {% set media = mediaList[0] %}
    {% set slide = slides[0]|default(null) %}
    {% if slide and (slide.title or slide.text) %}
        <div class="slider-single {{ class }}">
            {% if imageLinksToUrl and slide.url %}
                <a href="{{ slide.url }}" class="slider-img-link"><twig:c975LUi:Image:Image imgSrc="{{ vich_uploader_asset(media) }}" alt="{{ media.alt }}" label="{{ media.label }}" class="img-responsive img-rounded box-shadow" width="{{ media.width }}" height="{{ media.height }}" above="{{ media.above }}" /></a>
            {% else %}
                <twig:c975LUi:Image:Image imgSrc="{{ vich_uploader_asset(media) }}" alt="{{ media.alt }}" label="{{ media.label }}" class="img-responsive img-rounded box-shadow" width="{{ media.width }}" height="{{ media.height }}" above="{{ media.above }}" />
            {% endif %}
            {% if slide.title %}<p class="slider-title">{% if slide.url %}<a href="{{ slide.url }}">{{ slide.title }}</a>{% else %}{{ slide.title }}{% endif %}</p>{% endif %}
            {% if slide.text %}<p class="slider-text">{% if slide.url %}<a href="{{ slide.url }}">{{ slide.text }}</a>{% else %}{{ slide.text }}{% endif %}</p>{% endif %}
        </div>
    {% else %}
        <twig:c975LUi:Image:Image imgSrc="{{ vich_uploader_asset(media) }}" alt="{{ media.alt }}" label="{{ media.label }}" class="{{ ('img-responsive img-rounded box-shadow ' ~ class ~ ' ' ~ media.cssClasses|join(' '))|trim }}" width="{{ media.width }}" height="{{ media.height }}" above="{{ media.above }}" />
    {% endif %}
{% elseif mediaList|length > 1 %}
    <section id="{{ id }}" class="slider {{ ratio != "free" ? "slider-ratio-" ~ ratio : "" }} {{ class }}" aria-labelledby="{{ id }}-heading" data-controller="slider" data-slider-id="{{ id }}" data-slider-duration="{{ duration|default(0) }}">
        <h3 id="{{ id }}-heading" class="visuallyhidden">{{ label|default("Image slider") }}</h3>
        <ul class="slider-list">
        {% for slideMedia in mediaList %}
            {% set slide = slides[loop.index0]|default(null) %}
            <li class="slider-item"{% if not loop.first %} aria-hidden="true"{% endif %}>
                {% set img %}<img src="{{ vich_uploader_asset(slideMedia) }}" alt="{{ slideMedia.alt }}" class="slider-img img img-responsive img-rounded box-shadow {{ slideMedia.cssClasses|join(' ') }}" width="{{ slideMedia.width }}" height="{{ slideMedia.height }}" loading="{{ loop.first ? "eager" : "lazy" }}">{% endset %}
                {% if imageLinksToUrl and slide and slide.url %}<a href="{{ slide.url }}" class="slider-img-link">{{ img|raw }}</a>{% else %}{{ img|raw }}{% endif %}
                {% if slide and slide.title %}
                    <p class="slider-title">{% if slide.url %}<a href="{{ slide.url }}">{{ slide.title }}</a>{% else %}{{ slide.title }}{% endif %}</p>
                {% endif %}
                {% if slide and slide.text %}
                    <p class="slider-text">{% if slide.url %}<a href="{{ slide.url }}">{{ slide.text }}</a>{% else %}{{ slide.text }}{% endif %}</p>
                {% endif %}
                {% if slideMedia.rightsReserved %}
                    <p class="slider-rights-reserved">{{ "label.all_rights_reserved"|trans({}, "ui") }}</p>
                {% endif %}
                {% if slideMedia.credits %}
                    <p class="slider-credits">{{ "label.credits"|trans({}, "ui") }} : {{ slideMedia.credits }}</p>
                {% endif %}
            </li>
        {% endfor %}
        </ul>
        <div class="slider-controls">
            <button type="button" class="slider-button slider-prev" aria-label="{{ "label.previous_slide"|trans({}, "site") }}">
                <img src="{{ asset("bundles/c975lsite/icons/angle-left.svg") }}" alt="" aria-hidden="true" class="angle" width="32">
            </button>
            <button type="button" class="slider-button slider-next" aria-label="{{ "label.next_slide"|trans({}, "site") }}">
                <img src="{{ asset("bundles/c975lsite/icons/angle-right.svg") }}" alt="" aria-hidden="true" class="angle" width="32">
            </button>
            {% if duration|default(0) > 0 %}
                <button type="button" class="slider-play-pause" data-action="stop" aria-label="{{ "label.stop_animation"|trans({}, "site") }}">
                    <span aria-hidden="true">⏸</span>
                </button>
            {% endif %}
        </div>

        <ul class="slider-dots" aria-label="{{ "label.slide_navigation"|trans({}, "site") }}">
            {% for slideMedia in mediaList %}
                <li>
                    <button type="button" class="slider-dot{% if loop.first %} current active{% endif %}" data-slide="{{ loop.index0 }}" aria-label="{{ "label.slide"|trans({}, "site") }} {{ loop.index }}{% if loop.first %} ({{ "label.current"|trans({}, "site") }}){% endif %}">
                        <span aria-hidden="true">{{ loop.index }}</span>
                    </button>
                </li>
            {% endfor %}
        </ul>
    </section>
{% endif %}
