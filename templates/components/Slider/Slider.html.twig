{# Dynamic usage : {{ render_block(block) }} — block.media[] provides slides (images), data keys provide config #}
{# Static usage  : <twig:c975LUi:Slider:Slider media="{{ mediaList }}" id="id" duration="5000" [class=""] [label=""] /> #}
{% set label = label|default("label.pages_gallery"|trans({}, "site")) %}
{% set class = class|default("") %}
{% set mediaList = (block is defined and block.media is defined) ? block.media : (media|default([])) %}
{% if mediaList|length > 0 %}
    <section id="{{ id }}" class="slider {{ class }}" aria-labelledby="{{ id }}-heading" data-controller="slider" data-slider-id="{{ id }}" data-slider-duration="{{ duration|default(0) }}">
        <h3 id="{{ id }}-heading" class="visuallyhidden">{{ label|default("Image slider") }}</h3>
        <ul class="slider-list">
        {% for slideMedia in mediaList %}
            <li class="slider-item"{% if not loop.first %} aria-hidden="true"{% endif %}>
                <img src="{{ vich_uploader_asset(slideMedia) }}" alt="" class="slider-img img img-responsive img-rounded box-shadow" loading="{{ loop.first ? "eager" : "lazy" }}">
            </li>
        {% endfor %}
        </ul>
        {% if mediaList|length > 1 %}
            <div class="slider-controls">
                <button type="button" class="slider-button slider-prev" aria-label="{{ "label.previous_slide"|trans({}, "site") }}">
                    <img src="{{ asset("bundles/c975lsite/images/angle-left.svg") }}" alt="" aria-hidden="true" class="angle" width="32">
                </button>
                <button type="button" class="slider-button slider-next" aria-label="{{ "label.next_slide"|trans({}, "site") }}">
                    <img src="{{ asset("bundles/c975lsite/images/angle-right.svg") }}" alt="" aria-hidden="true" class="angle" width="32">
                </button>
                {% if duration|default(0) > 0 %}
                    <button type="button" class="slider-play-pause" data-action="stop" aria-label="{{ "label.stop_animation"|trans({}, "site") }}">
                        <span aria-hidden="true">⏸</span>
                    </button>
                {% endif %}
            </div>

            <ul class="slider-dots" aria-label="{{ "label.slide_navigation"|trans({}, "site") }}">
                {% for slideMedia in mediaList %}
                    <li>
                        <button type="button" class="slider-dot{% if loop.first %} current{% endif %}" data-slide="{{ loop.index0 }}" aria-label="{{ "label.slide"|trans({}, "site") }} {{ loop.index }}{% if loop.first %} ({{ "label.current"|trans({}, "site") }}){% endif %}">
                            <span aria-hidden="true">{{ loop.index }}</span>
                        </button>
                    </li>
                {% endfor %}
            </ul>
        {% endif %}
    </section>
{% endif %}
