{# Static usage: <twig:c975LUi:Hero:Hero title="..." primaryLabel="..." primaryUrl="..." [badge=""] [subtitle=""] [secondaryLabel=""] [secondaryUrl=""] [statValue=""] [statLabel=""] [src=""] [alt=""]/> #}
{# Dynamic usage (Block system): see templates/blocks/Hero.html.twig #}
<section class="hero">
    <div class="section-wrap">
        <div class="hero__text">
            {% if badge %}<span class="hero__badge">{{ badge }}</span>{% endif %}
            <h1 class="hero__title">{{ title|raw }}</h1>
            {% if subtitle %}<p class="hero__sub">{{ subtitle }}</p>{% endif %}
            <div class="hero__cta">
                <a class="section-btn section-btn--primary" href="{{ primaryUrl }}">{{ primaryLabel }}</a>
                {% if secondaryLabel %}<a class="section-btn section-btn--ghost" href="{{ secondaryUrl }}">{{ secondaryLabel }}</a>{% endif %}
            </div>
        </div>
        {% if src %}
            <div class="hero__media">
                <img src="{{ src }}" alt="{{ alt }}">
                {% if statValue %}<div class="hero__stat"><b>{{ statValue }}</b><span>{{ statLabel }}</span></div>{% endif %}
            </div>
        {% endif %}
    </div>
</section>
