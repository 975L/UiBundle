{# <twig:c975LUi:Video:Iframe src="your-url" [title="optional title"] [description="optional description"] [class="your-css-classes"] [width="auto"] [height="auto"]/> #}
{# The real <iframe> is only created client-side (see video-iframe.js), gated behind cookie consent -
   this markup stays identical regardless of consent state, so the block remains cacheable #}
<figure class="video-iframe-figure">
    {% if title is defined and title %}<h3 class="video-iframe-title">{{ title }}</h3>{% endif %}
    <div class="img img-responsive {{ class|default([])|join(' ') }} video-iframe-consent"
         data-controller="videoIframe"
         data-video-iframe-src-value="{{ src|privacy_embed_url }}"
         data-video-iframe-title-value="{{ title|default('') }}"
         data-video-iframe-width-value="{{ width|default('') }}"
         data-video-iframe-height-value="{{ height|default('') }}">
        <div data-video-iframe-target="placeholder" class="video-iframe-placeholder">
            <p>{{ 'label.video_iframe_consent_required'|trans({}, 'ui') }}</p>
            <button type="button" class="btn btn-primary" data-action="videoIframe#accept">
                {{ 'label.video_iframe_accept'|trans({}, 'ui') }}
            </button>
        </div>
    </div>
    {% if description is defined and description %}<figcaption class="video-iframe-description">{{ description|raw }}</figcaption>{% endif %}
</figure>
