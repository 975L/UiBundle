{# Static usage : <twig:c975LUi:Article:Article article="{{ article }}"/> #}
{# or explicit props : title="" content="" [detail=""] [mediaList=[]] [id=""] [uid=""] #}

{% set title = title|default(article.title|default('')) %}
{% set slug = slug|default(article.slug|default('')) %}
{% set content = content|default(article.content|default('')) %}
{% set detail = detail|default(article.detail|default('')) %}
{% set mediaList = mediaList|default(article is defined ? article.medias|default([]) : []) %}
{% set id = id|default('') %}
{# uid: technical suffix (e.g. the block's own id) to keep the slider's internal id unique
   when several instances could share the same slug (e.g. a duplicated block) - it must NOT
   affect the article's own id, which is used as a public anchor (#article-{slug}) #}
{% set uid = uid|default('') %}

<article class="site-article"{% if id %} id="{{ id }}"{% endif %}>
    <h2>{{ title }}</h2>
    {% if mediaList|length > 0 %}
        <twig:c975LUi:Slider:Slider media="{{ mediaList }}" id="{{ (id is defined and id) ? id ~ (uid ? '-' ~ uid : '') ~ '-slider' : 'article-' ~ slug }}" duration="3500"/>
    {% endif %}
    {{ content|raw|nl2br }}
</article>
