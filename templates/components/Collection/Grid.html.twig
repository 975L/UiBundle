{# Static usage: <twig:c975LUi:Collection:Grid items="{{ [...] }}" [eyebrow=""] [title=""] [linkLabel=""] [linkUrl=""] [variant=""] [id=""]/> #}
{# Dynamic usage (Block system): see templates/blocks/Collection.html.twig #}
{# Each entry in "items" is already-rendered HTML - one never-persisted "collection_item" Block per
   item (see CollectionExtension::renderItems()). Default variant reuses the same ".cards" flex wrap as
   several manually placed "card" blocks (see templates/components/Blocks/Blocks.html.twig,
   sass/_cards.scss); the "portfolio" variant needs its items' own ".portfolio-grid__project" markup
   (see CollectionItem.html.twig) laid out in PortfolioGrid's own CSS grid instead, or they'd wrap in
   this flexbox at whatever width each item's content happens to need - inconsistent with a real
   PortfolioGrid block sitting elsewhere on the same page. Same reasoning for the head markup below:
   the "portfolio" variant reuses PortfolioGrid's own ".portfolio-grid__head" (eyebrow + "voir tout"
   link), eyebrow/linkLabel/linkUrl are otherwise ignored - the default variant only ever shows title. #}
{% set isPortfolio = variant is defined and variant == 'portfolio' %}
<section class="collection-grid{{ isPortfolio ? ' collection-grid--portfolio' : '' }}"{% if id is defined and id %} id="{{ id }}"{% endif %}>
    <div class="section-wrap">
        {% if isPortfolio and (title or linkLabel) %}
            <div class="portfolio-grid__head">
                <div>
                    {% if eyebrow %}<p class="section-eyebrow">{{ eyebrow }}</p>{% endif %}
                    {% if title %}<h2 class="section-title">{{ title }}</h2>{% endif %}
                </div>
                {% if linkLabel %}<a class="section-btn section-btn--ghost" href="{{ linkUrl }}">{{ linkLabel }}</a>{% endif %}
            </div>
        {% elseif title %}
            <div class="collection-grid__head">
                <h2 class="section-title">{{ title }}</h2>
            </div>
        {% endif %}
        <div class="{{ isPortfolio ? 'portfolio-grid__grid' : 'cards' }}">
            {% for html in items %}
                {{ html|raw }}
            {% endfor %}
        </div>
    </div>
</section>
