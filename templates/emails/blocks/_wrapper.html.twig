{# Outer shell for an EmailTemplateRenderer::render() output - table layout, inline CSS, no JS/external CSS, so it survives every major email client (Outlook/Gmail/Apple Mail) unmodified #}
<!DOCTYPE html>
<html lang="en">
    <head>
        <meta charset="utf-8">
        <meta name="viewport" content="width=device-width, initial-scale=1.0">
        <title></title>
    </head>
    <body style="margin:0;padding:0;background-color:#f4f4f5;">
        <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0" style="background-color:#f4f4f5;">
            <tr>
                <td align="center" style="padding:24px 16px;">
                    <table role="presentation" width="600" cellpadding="0" cellspacing="0" border="0" style="max-width:600px;width:100%;background-color:#ffffff;border-radius:8px;">
                        <tr>
                            <td style="padding-top:8px;line-height:0;font-size:0;">&nbsp;</td>
                        </tr>
                        {% for block in blocksHtml %}
                            {{ block|raw }}
                        {% endfor %}
                        <tr>
                            <td style="padding-bottom:8px;line-height:0;font-size:0;">&nbsp;</td>
                        </tr>
                    </table>
                </td>
            </tr>
        </table>
    </body>
</html>
