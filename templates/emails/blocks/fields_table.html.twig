{# Renders the "fields" variable (label => submitted value pairs) passed to EmailTemplateRenderer::render() - e.g. a Form submission's answers, see SendEmailFormAction. Renders nothing if the caller didn't supply any #}
{% if fields is not empty %}
    <tr>
        <td style="padding:0 24px 24px;">
            <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0" style="border-collapse:collapse;font-family:Arial,Helvetica,sans-serif;font-size:14px;">
                {% for label, value in fields %}
                    <tr>
                        <td style="padding:8px 12px 8px 0;border-bottom:1px solid #eeeeee;color:#666666;white-space:nowrap;vertical-align:top;"><strong>{{ label }}</strong></td>
                        <td style="padding:8px 0;border-bottom:1px solid #eeeeee;color:#1a1a1a;">{{ value }}</td>
                    </tr>
                {% endfor %}
            </table>
        </td>
    </tr>
{% endif %}
