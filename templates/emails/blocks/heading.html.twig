<tr>
    <td style="padding:0 24px 16px;font-family:Arial,Helvetica,sans-serif;">
        {% if 'h1' == level %}
            <h1 style="margin:0;font-size:24px;line-height:32px;color:#1a1a1a;font-weight:bold;">{{ heading }}</h1>
        {% else %}
            <h2 style="margin:0;font-size:20px;line-height:28px;color:#1a1a1a;font-weight:bold;">{{ heading }}</h2>
        {% endif %}
    </td>
</tr>
