{# "Bulletproof" table-based button - the standard email-safe pattern, no CSS class relied upon (Outlook strips most <style> rules) #}
<tr>
    <td style="padding:0 24px 24px;">
        <table role="presentation" cellpadding="0" cellspacing="0" border="0">
            <tr>
                <td style="border-radius:4px;background-color:#2563eb;">
                    <a href="{{ url }}" target="_blank" style="display:inline-block;padding:12px 28px;font-family:Arial,Helvetica,sans-serif;font-size:15px;font-weight:bold;color:#ffffff;text-decoration:none;border-radius:4px;">{{ label }}</a>
                </td>
            </tr>
        </table>
    </td>
</tr>
