{% block icon_picker_widget %}
{%- set current_name = value is not empty ? value|split('/')|last|replace({'.svg': ''}) : '' -%}
{%- set icons_data = [] -%}
{%- for name, path in icons -%}
    {%- set icons_data = icons_data|merge([{name: name, path: path, url: asset(path)}]) -%}
{%- endfor -%}
<div class="ui-icon-picker" data-icons="{{ icons_data|json_encode|e('html_attr') }}">
    <input type="hidden" id="{{ id }}" name="{{ full_name }}"{% if value is not empty %} value="{{ value }}"{% endif %}>
    <input type="text"
           class="form-control ui-icon-search"
           placeholder="{{ 'label.search_icon'|trans({}, 'ui') }}"
           autocomplete="off"
           {% if current_name is not empty %}value="{{ current_name }}"{% endif %}>
    <div class="ui-icon-grid" hidden></div>
</div>
<script>
(function () {
    if (window._uiIconPickerReady) return;
    window._uiIconPickerReady = true;

    if (!document.getElementById('_ui-icon-picker-css')) {
        const s = document.createElement('style');
        s.id = '_ui-icon-picker-css';
        s.textContent = [
            '.ui-icon-picker{position:relative}',
            '.ui-icon-grid{display:flex;flex-wrap:wrap;gap:4px;max-height:220px;overflow-y:auto',
            ';border:1px solid #dee2e6;border-radius:.375rem;padding:8px',
            ';background:#fff;position:absolute;z-index:1050;min-width:100%}',
            '.ui-icon-item{border:none;background:none;padding:6px;cursor:pointer',
            ';border-radius:.25rem;display:flex;flex-direction:column;align-items:center',
            ';gap:2px;font-size:10px;max-width:64px;line-height:1.2}',
            '.ui-icon-item:hover{background:#e9ecef}',
            '.ui-icon-item img{width:24px;height:24px;object-fit:contain}',
            '.ui-icon-item span{overflow:hidden;text-overflow:ellipsis;white-space:nowrap;max-width:60px}',
        ].join('');
        document.head.appendChild(s);
    }

    function render(picker, query) {
        const icons = JSON.parse(picker.dataset.icons || '[]');
        const grid = picker.querySelector('.ui-icon-grid');
        const q = query.toLowerCase().trim();
        const filtered = q ? icons.filter(function (i) { return i.name.includes(q); }) : icons;

        if (!filtered.length) { grid.hidden = true; return; }

        grid.innerHTML = '';
        filtered.forEach(function (i) {
            const btn = document.createElement('button');
            btn.type = 'button';
            btn.className = 'ui-icon-item';
            btn.dataset.path = i.path;
            btn.title = i.name;
            const img = document.createElement('img');
            img.src = i.url;
            img.width = 24;
            img.height = 24;
            img.loading = 'lazy';
            img.alt = '';
            const span = document.createElement('span');
            span.textContent = i.name;
            btn.appendChild(img);
            btn.appendChild(span);
            grid.appendChild(btn);
        });
        grid.hidden = false;
    }

    document.addEventListener('input', function (e) {
        if (!e.target.classList.contains('ui-icon-search')) return;
        const picker = e.target.closest('.ui-icon-picker');
        if (!e.target.value) picker.querySelector('input[type="hidden"]').value = '';
        render(picker, e.target.value);
    });

    document.addEventListener('focusin', function (e) {
        if (!e.target.classList.contains('ui-icon-search')) return;
        if (!e.target.value) render(e.target.closest('.ui-icon-picker'), '');
    });

    document.addEventListener('click', function (e) {
        const item = e.target.closest('.ui-icon-item');
        if (item) {
            const picker = item.closest('.ui-icon-picker');
            picker.querySelector('input[type="hidden"]').value = item.dataset.path;
            picker.querySelector('.ui-icon-search').value = item.title;
            picker.querySelector('.ui-icon-grid').hidden = true;
            return;
        }
        if (!e.target.classList.contains('ui-icon-search')) {
            document.querySelectorAll('.ui-icon-grid').forEach(function (g) { g.hidden = true; });
        }
    });
})();
</script>
{% endblock %}
