{# form_widget(form) must never be called recursively from within the block it resolved to: Symfony's
   FormRenderer treats that as "render the parent TYPE's block", not "re-render this same block from the
   default theme" - for trix_editor/textarea (whose parent type is textarea/text respectively) that silently
   downgrades the field to a <input type="text"> (text_widget) instead of a real <textarea>. Render the
   actual tag directly instead, mirroring Symfony's own textarea_widget (form_div_layout.html.twig) #}
{% block trix_editor_widget %}
    {% set attr = attr|merge({
        class: (attr.class|default('') ~ ' form-control ea-text-editor-content d-none')|trim,
        'data-number-of-rows': '5',
        'data-trix-editor-config': 'null',
    }) %}
    <textarea {{ block('widget_attributes') }}>{{ value }}</textarea>

    {% if ai_rephrase_enabled() %}
        {{ include('@c975LUi/form/_ai_rephrase.html.twig', {field_id: form.vars.id}) }}
    {% endif %}
{% endblock %}

{# Unlike trix_editor_widget, opt-in only (attr['data-ai-rephrase'] must be set): a plain textarea is
   used dashboard-wide for everything from prose content to raw JSON/technical config values (e.g.
   ConfigBundle's Config CRUD renders json-kind values through this exact same block) - showing the
   button unconditionally on every textarea would be actively wrong there. A field opts in with e.g.
   TextareaField::new('summary')->setFormTypeOption('attr', {'data-ai-rephrase': 'true'}) #}
{% block textarea_widget %}
    {# EasyAdmin's own CSS only styles "textarea.form-control" (see easyadmin-theme/forms.css) - Symfony's
       built-in textarea_widget never adds that class itself (only form_widget_simple's input-based blocks
       do), so without it the browser falls back to a native <textarea>'s tiny default width #}
    {% set attr = attr|merge({class: (attr.class|default('') ~ ' form-control')|trim}) %}
    <textarea {{ block('widget_attributes') }}>{{ value }}</textarea>

    {% if attr['data-ai-rephrase'] is defined and ai_rephrase_enabled() %}
        {{ include('@c975LUi/form/_ai_rephrase.html.twig', {field_id: form.vars.id}) }}
    {% endif %}
{% endblock %}

{% block empty_collection %}
<div class="empty collection-empty"></div>
{% endblock %}
