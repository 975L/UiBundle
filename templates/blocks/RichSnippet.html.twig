{# Adapter for the dynamic Block system — maps Block data to the General:RichSnippet component #}
<twig:c975LUi:General:RichSnippet
    itemscope="{{ itemscope }}"
    name="{{ name }}"
    description="{{ description }}"
    telephone="{{ telephone }}"
    image="{{ image }}"
    openingHours="{{ openingHours }}"
    priceRange="{{ priceRange }}"
    addressStreetAddress="{{ addressStreetAddress }}"
    addressPostalCode="{{ addressPostalCode }}"
    addressAddressLocality="{{ addressAddressLocality }}"
    addressAddressCountryCode="{{ addressAddressCountryCode }}"
    addressAddressCountryName="{{ addressAddressCountryName }}"
/>
