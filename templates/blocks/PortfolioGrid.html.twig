{# Adapter for the dynamic Block system — maps Block data/media to the Portfolio:Grid component #}
<twig:c975LUi:Portfolio:Grid
    eyebrow="{{ eyebrow|default('') }}"
    title="{{ title|default('') }}"
    linkLabel="{{ linkLabel|default('') }}"
    linkUrl="{{ linkUrl|default('') }}"
    media="{{ block.media }}"
/>
