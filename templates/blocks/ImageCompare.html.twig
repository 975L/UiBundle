{# Adapter for the dynamic Block system — maps Block media (ordered: first = before, second = after) to the ImageCompare component #}
<twig:c975LUi:ImageCompare:ImageCompare media="{{ block.media }}" id="{{ id }}" startPosition="{{ startPosition|default(50) }}" beforeLabel="{{ beforeLabel|default('') }}" afterLabel="{{ afterLabel|default('') }}" class="{{ class }}"/>
