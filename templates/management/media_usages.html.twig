{# @var field \EasyCorp\Bundle\EasyAdminBundle\Dto\FieldDto #}
{# @var entity \EasyCorp\Bundle\EasyAdminBundle\Dto\EntityDto #}
{% set usages = field.formattedValue %}
<p class="mb-2"><strong>{{ 'label.id'|trans({}, 'ui') }} :</strong> {{ entity.instance.id }}</p>
{% if usages is empty %}
    <span class="text-muted">{{ 'label.not_used_anywhere'|trans({}, 'ui') }}</span>
{% else %}
    <ul class="list-unstyled mb-0">
        {% for usage in usages %}
            <li>
                {% if usage.url %}
                    <a href="{{ usage.url }}" target="_blank" rel="noopener">{{ usage.label }}</a>
                {% else %}
                    {{ usage.label }}
                {% endif %}
            </li>
        {% endfor %}
    </ul>
{% endif %}
