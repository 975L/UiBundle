{% extends '@EasyAdmin/layout.html.twig' %}
{% import _self as gallery %}

{% block content_title %}{{ 'label.block_gallery'|trans({}, 'ui') }}{% endblock %}

{# Renders arbitrary trusted HTML (a rendered block, or a showcased component/function) inside its own
   isolated document (own front-end stylesheets, e.g. Alert's colors come from SiteBundle's, not
   UiBundle's - see bundle_stylesheets()) so the site's CSS never bleeds into this EasyAdmin page's own
   chrome, and vice versa. Resized to fit its content by the "galleryPreview" Stimulus controller.
   gallery-preview.min.css is a real linked stylesheet, not an inline <style> - a site enforcing a CSP
   without 'unsafe-inline' on style-src would silently drop an inline block, with no visible difference
   from "the rule just doesn't apply" (this is exactly what broke share_buttons() here once). #}
{% macro previewIframe(html, title) %}
    {% set previewDoc %}<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8">
    {% for href in bundle_stylesheets() %}<link rel="stylesheet" href="{{ href }}">{% endfor %}
    <link rel="stylesheet" href="{{ asset('bundles/c975lui/css/gallery-preview.min.css') }}">
</head>
<body>{{ html|raw }}</body>
</html>
{% endset %}
    <iframe
        class="block-gallery-item__iframe"
        srcdoc="{{ previewDoc|e('html_attr') }}"
        title="{{ title }}"
        data-controller="galleryPreview"
        loading="lazy"
    ></iframe>
{% endmacro %}

{% block main %}
    <p>{{ 'label.block_gallery_info'|trans({}, 'ui') }}</p>

    {# Single pass over "previews": tocItems is collected as a side effect while the cards themselves are
       captured into cardsHtml, so both the table of contents and the listing come from walking the
       (category -> kind -> item) structure once, not twice. #}
    {% set tocItems = [] %}
    {% set cardsHtml %}
        {% for category, items in previews %}
            <h2 class="block-gallery-category">{{ category }}</h2>
            {% for key, item in items %}
                {% set tocItems = tocItems|merge([{key: key, label: item.label}]) %}
                <div class="block-gallery-item" id="block-{{ key }}">
                    <h3 class="block-gallery-item__title">{{ item.label }}</h3>
                    {% if item.kind %}
                        <p class="block-gallery-item__slug text-muted">({{ item.kind }})</p>
                    {% endif %}
                    {% if item.description %}
                        <p class="block-gallery-item__description text-muted">{{ item.description }}</p>
                    {% endif %}

                    {% if item.variants|length > 0 %}
                        {% for variantLabel, variant in item.variants %}
                            <div class="block-gallery-item__frame">
                                {% if variantLabel %}
                                    <p class="block-gallery-item__variant text-muted">{{ variantLabel }}</p>
                                {% endif %}
                                {{ gallery.previewIframe(
                                    'block' == variant.type ? render_block(variant.content) : variant.content,
                                    item.label ~ (variantLabel ? ' - ' ~ variantLabel : '')
                                ) }}
                            </div>
                        {% endfor %}
                    {% else %}
                        <p class="block-gallery-item__empty text-muted">{{ 'label.block_gallery_no_example'|trans({}, 'ui') }}</p>
                    {% endif %}
                </div>
            {% endfor %}
        {% endfor %}
    {% endset %}

    {# One flat table of contents across every category, mirroring 975l.com's public "vitrine des
       blocks" page - a long alphabetic scroll of 30+ kinds is hard to navigate without it #}
    <ul class="block-gallery-toc">
        {% for tocItem in tocItems %}
            <li><a href="#block-{{ tocItem.key }}">{{ tocItem.label }}</a></li>
        {% endfor %}
    </ul>

    {{ cardsHtml|raw }}
{% endblock %}
