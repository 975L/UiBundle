{
    "name": "c975l/ui-bundle",
    "type": "symfony-bundle",
    "description": "Symfony bundle providing the c975L ecosystem's shared front-end foundation — dynamic blocks, media library, and reusable CSS/JS/font/form registries used by every satellite bundle.",
    "keywords": ["symfony", "bundle", "ui"],
    "license": "MIT",
    "authors": [
        {
            "name": "Laurent Marquet",
            "email": "laurent.marquet@laposte.net",
            "homepage": "https://github.com/LaurentMarquet",
            "role": "Developer"
        },
        {
            "name": "975L Community",
            "homepage": "https://github.com/975L"
        }
    ],
    "require": {
        "php": ">=8.0",
        "c975l/config-bundle": "*",
        "doctrine/orm": "*",
        "easycorp/easyadmin-bundle": "^5.1",
        "egulias/email-validator": "*",
        "imagine/imagine": "*",
        "karser/karser-recaptcha3-bundle": "*",
        "sensiolabs/minify-bundle": "*",
        "symfony/form": "*",
        "symfony/http-client": "*",
        "symfony/mailer": "*",
        "symfony/security-bundle": "*",
        "symfony/yaml": "*",
        "vich/uploader-bundle": "*"
    },
    "require-dev": {
        "doctrine/doctrine-fixtures-bundle": "*",
        "nelmio/security-bundle": "*",
        "phpunit/phpunit": "^13.2",
        "symfony/browser-kit": "*",
        "symfony/css-selector": "*",
        "symfony/maker-bundle": "*",
        "symfony/phpunit-bridge": "*",
        "symfony/rate-limiter": "^8.1",
        "symfony/var-dumper": "*"
    },
    "minimum-stability": "dev",
    "prefer-stable": true,
    "autoload": {
        "psr-4": {
            "c975L\\UiBundle\\": "src/",
            "c975L\\UiBundle\\Migrations\\": "migrations/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "c975L\\UiBundle\\Tests\\": "tests/"
        }
    },
    "config": {
        "sort-packages": true
    },
    "scripts": {
        "test": "phpunit"
    },
    "support": {
        "email": "contact@975l.com",
        "source": "https://github.com/975L/UiBundle",
        "issues": "https://github.com/975L/UiBundle/issues"
    }
}
